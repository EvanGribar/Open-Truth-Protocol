# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Object Storage
S3_ENDPOINT=http://localhost:4566
S3_BUCKET_INTAKE=otp-intake
S3_BUCKET_MODELS=otp-models
AWS_ACCESS_KEY_ID=dev
AWS_SECRET_ACCESS_KEY=dev
AWS_REGION=us-east-1

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=otp-orchestrator

# Redis
REDIS_URL=redis://localhost:6379/0

# Service
OTP_ENV=development
OTP_LOG_LEVEL=INFO
OTP_API_HOST=0.0.0.0
OTP_API_PORT=8000

# Optional: Web Consensus external providers (Phase 2)
TAVILY_API_KEY=
SERPAPI_KEY=
WEAVIATE_URL=http://localhost:8080
GOOGLE_FACT_CHECK_API_KEY=

# Optional: Ledger commitment infrastructure (Phase 3)
ARBITRUM_RPC_URL=
OTP_CONTRACT_ADDRESS=
LEDGER_WALLET_PRIVATE_KEY=
PINATA_JWT=
WEB3_STORAGE_TOKEN=
